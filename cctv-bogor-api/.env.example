# ── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://traffic_user:traffic_dev_pass@localhost:5432/traffic_monitor
POSTGRES_PASSWORD=traffic_dev_pass

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=1800

# ── Traffic thresholds (global defaults, overridden per-CCTV in DB) ──
DEFAULT_THRESHOLD_LOW=10
DEFAULT_THRESHOLD_HIGH=25

# ── Vertex AI AutoML Vision ───────────────────────────────────
VERTEX_AI_MOCK=true                          # set false in production
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=asia-southeast1
VERTEX_AI_ENDPOINT_ID=your-automl-endpoint-id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
